---
import Layout from "../layouts/Layout.astro";
---

<Layout title="页面未找到 · 每日一书" description="您访问的页面不存在">
  <div class="not-found">
    <div class="not-found-icon">📖</div>
    <h1 class="not-found-title">页面未找到</h1>
    <p class="not-found-desc">您访问的页面似乎已经漂流到了别处...</p>
    <a href="/" class="not-found-btn">返回首页</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 48px 24px;
  }

  .not-found-icon {
    font-size: 80px;
    margin-bottom: 24px;
    opacity: 0.6;
  }

  .not-found-title {
    font-size: 32px;
    font-weight: 700;
    margin: 0 0 16px;
    color: var(--text-primary);
  }

  .not-found-desc {
    font-size: 16px;
    color: var(--text-secondary);
    margin: 0 0 32px;
    max-width: 360px;
  }

  .not-found-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: linear-gradient(135deg, var(--accent), var(--accent-light));
    color: #0a0a0f;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px var(--accent-glow);
  }

  .not-found-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(212, 168, 83, 0.35);
  }
</style>
