---
import Layout from "../layouts/Layout.astro";
import { getRecentBooks, formatDate, formatDateShort, formatDateISO } from "../data/books";

const recent = getRecentBooks(30);
---

<Layout title="往期回顾 · 每日一书" description="查看过去30天的每日推荐书籍">
  <div style="padding: 32px 0 16px;">
    <h1 class="page-title">往期回顾</h1>
    <p class="page-desc">过去 30 天的每日推荐，每一本都值得细细品读。</p>
  </div>

  <div class="archive-grid">
    {recent.map(({ date, book }) => (
      <a href={`/book/${formatDateISO(date)}`} class="history-card">
        <div class="history-date">{formatDate(date)}</div>
        <div class="history-title">{book.title}</div>
        <div class="history-author">{book.author}</div>
        <div class="history-quote">&ldquo;{book.quotes[0].text.substring(0, 50)}&hellip;&rdquo;</div>
      </a>
    ))}
  </div>
</Layout>
