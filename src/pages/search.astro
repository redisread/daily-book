---
import Layout from "../layouts/Layout.astro";
import { books, getAllCategories, getBookDateMap } from "../data/books";

const categories = getAllCategories();
const bookDateMap = getBookDateMap();

const searchBooks = books.map((book) => ({
  id: book.id,
  title: book.title,
  author: book.author,
  category: book.category,
  coverBg: book.coverBg,
  coverTitle: book.coverTitle,
  coverAuthor: book.coverAuthor,
  desc: book.desc,
  date: bookDateMap.get(book.id) || book.id,
}));
---

<Layout title="搜索书籍 · 每日一书" description="搜索书名、作者或按类别筛选书籍">
  <div class="search-page" style="padding: 32px 0 16px;">
    <h1 class="page-title">搜索书籍</h1>
    <p class="page-desc">搜索书名、作者或按类别筛选，发现你喜欢的书籍。</p>
  </div>

  <div class="search-container">
    <div class="search-form">
      <div class="search-input-wrapper">
        <input
          type="text"
          id="searchInput"
          class="search-input"
          placeholder="搜索书名或作者..."
          autocomplete="off"
        />
        <button type="button" class="search-btn" id="searchBtn" aria-label="搜索">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
      </div>

      <div class="category-filters" id="categoryFilters" role="group" aria-label="类别筛选">
        <button type="button" class="category-btn active" data-category="">全部</button>
        {categories.map((cat) => (
          <button type="button" class="category-btn" data-category={cat}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="results-container">
    <div class="results-header">
      <span class="results-count" id="resultsCount">共 {searchBooks.length} 本书</span>
    </div>

    <div id="resultsContainer">
      <div class="books-grid" id="booksGrid">
        {searchBooks.map((book) => (
          <a href={`/book/${book.date}`} class="book-card" data-title={book.title} data-author={book.author} data-category={book.category}>
            <div class="book-cover" style={`background: ${book.coverBg}`}>
              <div class="book-cover-title">{book.coverTitle}</div>
              <div class="book-cover-author">{book.coverAuthor}</div>
            </div>
            <div class="book-info">
              <h3 class="book-title">{book.title}</h3>
              <p class="book-author">{book.author}</p>
              <span class="book-category">{book.category}</span>
              <p class="book-desc">{book.desc.substring(0, 80)}...</p>
            </div>
          </a>
        ))}
      </div>
      <div class="empty-state" id="emptyState" hidden>
        <div class="empty-icon">📚</div>
        <p>未找到相关书籍</p>
        <p class="empty-hint">尝试其他关键词或类别</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('searchInput');
  const searchBtn = document.getElementById('searchBtn');
  const categoryButtons = document.querySelectorAll('.category-btn');
  const cards = document.querySelectorAll('.book-card');
  const resultsCount = document.getElementById('resultsCount');
  const emptyState = document.getElementById('emptyState');
  const booksGrid = document.getElementById('booksGrid');

  let currentCategory = '';

  function updateFilter() {
    const query = (searchInput as HTMLInputElement).value.toLowerCase().trim();
    let visible = 0;

    cards.forEach((card) => {
      const title = card.getAttribute('data-title') || '';
      const author = card.getAttribute('data-author') || '';
      const category = card.getAttribute('data-category') || '';
      const matchesQuery = !query || title.toLowerCase().includes(query) || author.toLowerCase().includes(query);
      const matchesCategory = !currentCategory || category === currentCategory;
      const show = matchesQuery && matchesCategory;
      (card as HTMLElement).hidden = !show;
      if (show) visible++;
    });

    const queryText = query ? `搜索: "${query}"` : '';
    const categoryText = currentCategory ? `类别: ${currentCategory}` : '';
    resultsCount!.innerHTML = `找到 ${visible} 本书` +
      (queryText ? ` <span class="search-term">${queryText}</span>` : '') +
      (categoryText ? ` <span class="filter-term">${categoryText}</span>` : '');

    emptyState!.hidden = visible > 0;
    booksGrid!.hidden = visible === 0;
  }

  searchInput?.addEventListener('input', updateFilter);
  searchBtn?.addEventListener('click', updateFilter);
  searchInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') updateFilter();
  });

  categoryButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      categoryButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentCategory = btn.getAttribute('data-category') || '';
      updateFilter();
    });
  });
</script>
