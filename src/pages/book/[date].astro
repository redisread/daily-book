---
import Layout from "../../layouts/Layout.astro";
import BookCard from "../../components/BookCard.astro";
import QuoteCard from "../../components/QuoteCard.astro";
import HistoryGrid from "../../components/HistoryGrid.astro";
import { getBookForDate, getPublishedDates, formatDate, formatDateISO } from "../../data/books";

export function getStaticPaths() {
  return getPublishedDates().map((date) => ({ params: { date } }));
}

const { date: dateParam } = Astro.params;
const [year, month, day] = dateParam!.split("-").map(Number);
const date = new Date(year, month - 1, day);
const book = getBookForDate(date);
const dateStr = formatDate(date);

// Book schema JSON-LD（结构化数据，利于搜索引擎富媒体展示）
const bookSchema = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: book.title,
  author: { "@type": "Person", name: book.author },
  datePublished: book.year,
  numberOfPages: book.pages || undefined,
  bookFormat: "https://schema.org/Hardcover",
  description: book.desc,
  inLanguage: "zh-CN",
  aggregateRating: book.rating
    ? { "@type": "AggregateRating", ratingValue: book.rating, bestRating: "10" }
    : undefined,
};
---

<Layout title={`${book.title} · ${dateStr} · 每日一书`} description={`${dateStr}推荐《${book.title}》—— ${book.quotes[0].text}`} jsonLd={bookSchema}>
  <div class="date-bar">
    <div class="date-info">
      <div class="date-main">{dateStr}</div>
      <div class="date-reading-day">
        {formatDateISO(date) === formatDateISO(new Date()) ? "今日推荐" : "往期推荐"}
      </div>
    </div>
    <div class="date-nav">
      <a href="/" class="date-arrow" title="回到今天" style="font-size: 12px; font-weight: 600; text-decoration: none;">今</a>
    </div>
  </div>

  <BookCard book={book} />
  <QuoteCard book={book} />
  <HistoryGrid days={6} />
</Layout>
