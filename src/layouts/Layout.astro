---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "每日一书 · Daily Book",
  description = "每天推荐一本好书，附带精选金句，让阅读成为习惯。",
  image = "/og-image.png",
  jsonLd,
} = Astro.props;

const site = Astro.site ?? new URL("https://daily-book.pages.dev");
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(image, site);
const fullTitle = title === "每日一书 · Daily Book" ? title : `${title} · 每日一书`;

// Default WebSite JSON-LD（每页都有），如调用方传 jsonLd 则追加
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "每日一书",
  alternateName: "Daily Book",
  url: site.href,
  description: "每天推荐一本好书，附带精选金句",
  inLanguage: "zh-CN",
  potentialAction: {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: `${site.href}search?q={query}` },
    "query-input": "required name=query",
  },
};
const allSchemas: Record<string, unknown>[] = [websiteSchema];
if (jsonLd) {
  if (Array.isArray(jsonLd)) allSchemas.push(...jsonLd);
  else allSchemas.push(jsonLd);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="每日一书 RSS" href="/rss.xml" />

    <!-- Resource prefetch/preconnect -->
    <link rel="dns-prefetch" href="//static.cloudflareinsights.com" />
    <link rel="preconnect" href="https://static.cloudflareinsights.com" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="每日一书" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <!-- JSON-LD Structured Data -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <title>{title}</title>
  </head>
  <body>
    <!-- Background -->
    <div class="ambient-bg">
      <div class="ambient-orb"></div>
      <div class="ambient-orb"></div>
      <div class="ambient-orb"></div>
    </div>
    <div class="grain"></div>

    <div class="app-container">
      <!-- Skip to content for keyboard users -->
      <a href="#main-content" class="skip-link">跳到主内容</a>

      <!-- Header -->
      <header class="header">
        <a href="/" class="logo" aria-label="每日一书 首页">
          <div class="logo-icon" aria-hidden="true">📖</div>
          <div>
            <div class="logo-text">每日一书</div>
            <div class="logo-sub">Daily Book</div>
          </div>
        </a>
        <nav class="header-nav" aria-label="主导航">
          <a href="/" class="nav-btn active" data-nav="home">今日推荐</a>
          <a href="/archive" class="nav-btn" data-nav="archive">往期回顾</a>
          <a href="/search" class="nav-btn" data-nav="search">搜索</a>
          <a href="/rss.xml" class="nav-btn" target="_blank" rel="noopener" title="RSS 订阅">RSS</a>
        </nav>
      </header>

      <main id="main-content">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="footer">
        <span>每日一书 &copy; {new Date().getFullYear()}</span>
        <a href="/rss.xml" target="_blank">RSS 订阅</a>
      </footer>
    </div>

    <!-- Mobile Bottom Navigation -->
    <nav class="mobile-nav" id="mobileNav">
      <ul class="mobile-nav-list">
        <li class="mobile-nav-item">
          <a href="/" class="mobile-nav-link" data-nav="home">
            <span class="mobile-nav-icon">📖</span>
            <span>今日</span>
          </a>
        </li>
        <li class="mobile-nav-item">
          <a href="/archive" class="mobile-nav-link" data-nav="archive">
            <span class="mobile-nav-icon">📚</span>
            <span>往期</span>
          </a>
        </li>
        <li class="mobile-nav-item">
          <a href="/search" class="mobile-nav-link" data-nav="search">
            <span class="mobile-nav-icon">🔍</span>
            <span>搜索</span>
          </a>
        </li>
        <li class="mobile-nav-item">
          <a href="/rss.xml" class="mobile-nav-link" target="_blank">
            <span class="mobile-nav-icon">📡</span>
            <span>RSS</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Toast -->
    <div class="toast" id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

    <script>
      // Highlight active nav
      const path = window.location.pathname;
      document.querySelectorAll('.nav-btn').forEach((btn) => {
        btn.classList.remove('active');
        const href = btn.getAttribute('href');
        if (href === '/' && (path === '/' || path.startsWith('/book/'))) {
          btn.classList.add('active');
        } else if (href && href !== '/' && path.startsWith(href)) {
          btn.classList.add('active');
        }
      });

      // Highlight mobile nav
      document.querySelectorAll('.mobile-nav-link').forEach((link) => {
        link.classList.remove('active');
        const href = link.getAttribute('href');
        const nav = link.getAttribute('data-nav');
        if (href === '/' && (path === '/' || path.startsWith('/book/'))) {
          if (nav === 'home') link.classList.add('active');
        } else if (href && href !== '/' && path.startsWith(href)) {
          link.classList.add('active');
        }
      });

      // Toast utility
      window.showToast = function(msg: string) {
        const toast = document.getElementById('toast');
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
      };
    </script>
  </body>
</html>
