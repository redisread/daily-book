---
import type { Book } from "../data/books";

interface Props {
  book: Book;
}

const { book } = Astro.props;
---

<div class="hero-card" data-book-title={book.title}>
  <div class="hero-content">
    <div class="book-cover-section">
      <div class="book-cover" id="bookCover">
        <div class="book-spine"></div>
        <div class="book-cover-placeholder" style={`background: ${book.coverBg};`}>
          <div class="cover-title" set:text={book.coverTitle} />
          <div class="cover-divider"></div>
          <div class="cover-author">{book.coverAuthor}</div>
        </div>
      </div>
      <!-- Cover Lightbox -->
      <div class="cover-lightbox" id="coverLightbox">
        <div class="lightbox-backdrop"></div>
        <div class="lightbox-content">
          <div class="book-cover enlarged" id="enlargedCover">
            <div class="book-spine"></div>
            <div class="book-cover-placeholder" style={`background: ${book.coverBg};`}>
              <div class="cover-title" set:text={book.coverTitle} />
              <div class="cover-divider"></div>
              <div class="cover-author">{book.coverAuthor}</div>
            </div>
          </div>
          <button class="lightbox-close" id="lightboxClose" aria-label="关闭">✕</button>
        </div>
      </div>
    </div>
    <div class="book-info-section">
      <div class="book-category">{book.category}</div>
      <h1 class="book-title">{book.title}</h1>
      <p class="book-author"><span>{book.author}</span></p>
      <p class="book-desc">{book.desc}</p>
      <div class="book-meta">
        <div class="meta-item">
          <span class="meta-label">出版年份</span>
          <span class="meta-value">{book.year}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">页数</span>
          <span class="meta-value">{book.pages}页</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">评分</span>
          <span class="meta-value">⭐ {book.rating}</span>
        </div>
      </div>
      <div class="book-actions">
        <button class="btn-primary" data-action="markRead" data-title={book.title}>📚 标记已读</button>
        <button class="btn-secondary" data-action="collect" data-title={book.title}>♡ 收藏</button>
        <a href="/rss.xml" class="btn-rss" target="_blank">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
          RSS
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  import { initLightbox } from "../scripts/lightbox";
  import { initBookActions } from "../scripts/storage";

  // 从 DOM 获取 bookTitle（不再依赖 define:vars）
  const heroCard = document.querySelector('.hero-card');
  const bookTitle = heroCard?.getAttribute('data-book-title') ?? '';

  initLightbox();
  initBookActions(bookTitle);
</script>
