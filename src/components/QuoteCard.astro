---
import type { Book } from "../data/books";

interface Props {
  book: Book;
}

const { book } = Astro.props;
const quotes = book.quotes;
const moreQuotes = quotes.slice(1, 5);
---

<!-- Featured Quote with Swipe -->
<div class="quote-swipe-container" id="quoteSwipeContainer">
  <div class="quote-swipe-track" id="quoteSwipeTrack">
    {quotes.map((q, index) => (
      <div class="quote-card" data-index={index}>
        <div class="quote-mark">&ldquo;</div>
        <p class="quote-text">{q.text}</p>
        <div class="quote-source">
          ——{book.author}《{book.title}》{q.page}
        </div>
        <div class="quote-actions">
          <button class="quote-action-btn like-btn" data-index={index} title="喜欢">♡</button>
          <button class="quote-action-btn share-btn" data-index={index} data-quote={q.text} data-source={`——${book.author}《${book.title}》${q.page}`} title="分享">⎘</button>
          <button class="quote-action-btn image-btn" data-index={index} data-quote={q.text} data-source={`——${book.author}《${book.title}》${q.page}`} title="生成图片">🖼</button>
        </div>
      </div>
    ))}
  </div>
  <div class="quote-swipe-dots" id="quoteSwipeDots"></div>
  <div class="quote-swipe-hint">← 左右滑动切换金句 →</div>
</div>

<!-- Share Image Modal -->
<div class="share-modal" id="shareModal">
  <div class="share-modal-backdrop"></div>
  <div class="share-modal-content">
    <button class="share-modal-close" id="shareModalClose">✕</button>
    <div class="share-preview" id="sharePreview">
      <p class="share-preview-quote" id="sharePreviewQuote"></p>
      <p class="share-preview-source" id="sharePreviewSource"></p>
    </div>
    <div class="share-actions">
      <button class="share-btn share-btn-primary" id="downloadShareImage">下载图片</button>
      <button class="share-btn share-btn-secondary" id="copyShareText">复制文字</button>
    </div>
  </div>
</div>

<!-- More Quotes -->
{moreQuotes.length > 0 && (
  <div class="more-quotes">
    <div class="section-header">
      <h2 class="section-title">更多金句</h2>
    </div>
    <div class="quotes-grid">
      {moreQuotes.map((q) => (
        <div class="mini-quote-card" data-quote={q.text} data-source={`——${book.author}《${book.title}》${q.page}`}>
          <p class="mini-quote-text">{q.text}</p>
          <span class="mini-quote-page">{q.page}</span>
        </div>
      ))}
    </div>
  </div>
)}

<script>
  import { initQuoteSwipe, initQuoteActions } from "../scripts/quote-swipe";

  initQuoteSwipe();
  initQuoteActions();
</script>
